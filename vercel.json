{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/join", "destination": "/join.html" },
    { "source": "/account", "destination": "/account.html" },
    { "source": "/davidparmley", "destination": "/artists/david-parmley.html" },
    { "source": "/artists/david-parmley", "destination": "/artists/david-parmley.html" }
  ]
}